 import { Renderer } from "@takumi-rs/core";
 import { container, image, text } from "@takumi-rs/helpers";
 import type { Node } from "@takumi-rs/helpers";
+import { readFileSync } from "node:fs";
+import { resolve } from "node:path";
 
 import { OG_IMAGE_HEIGHT, OG_IMAGE_WIDTH } from "./dimensions.ts";
 
+// LOCAL PATCH (patch-package, not upstream Blume): Takumi's built-in
+// last-resort font (Geist) only covers Latin glyphs, so any CJK text in an
+// OG card renders as tofu. Takumi falls back per-glyph across every loaded
+// font ("a missing glyph walks the chain until a family covers it"), so
+// loading a Japanese-capable font here fixes Japanese titles/descriptions
+// without touching how Latin text renders. Upstream has no config surface to
+// supply OG fonts at all (see https://github.com/haydenbleasel/blume) — this
+// patch is a stand-in for a real `seo.og.fonts`-style option; drop it once
+// that lands.
+const loadJapaneseOgFonts = (target: Renderer): void => {
+  try {
+    const dir = resolve(process.cwd(), "assets/og-fonts");
+    target.loadFontSync({
+      data: readFileSync(resolve(dir, "NotoSansJP-Regular.otf")),
+      name: "Noto Sans JP",
+      weight: 400,
+    });
+    target.loadFontSync({
+      data: readFileSync(resolve(dir, "NotoSansJP-Bold.otf")),
+      name: "Noto Sans JP",
+      weight: 700,
+    });
+  } catch {
+    // No local font bundle at assets/og-fonts (e.g. a consumer without this
+    // patch's assets) — silently keep Takumi's Latin-only default.
+  }
+};
+
 // Reuse one renderer (and its loaded default fonts) across all images.
 let renderer: Renderer | null = null;
 const getRenderer = (): Renderer => {
-  renderer ??= new Renderer();
+  if (!renderer) {
+    renderer = new Renderer();
+    loadJapaneseOgFonts(renderer);
+  }
   return renderer;
 };
 
